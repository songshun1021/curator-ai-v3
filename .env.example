# Curator AI env example
# Most end users do not need this file.
# Recommended deployment mode:
# 1. Deploy the web app
# 2. Let each user fill provider / model / baseURL / apiKey in the browser UI
# 3. Do not commit real keys

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional platform trial mode
# Recommended Bailian mainland setup:
# PLATFORM_PROVIDER=通义千问
# PLATFORM_MODEL=qwen3.6-flash
# PLATFORM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PLATFORM_ENABLE_THINKING=false
PLATFORM_TRIAL_ENABLED=false
PLATFORM_PROVIDER=
PLATFORM_MODEL=
PLATFORM_BASE_URL=
PLATFORM_API_KEY=
PLATFORM_ENABLE_THINKING=
FREE_TRIAL_INPUT_TOKENS=400000
FREE_TRIAL_OUTPUT_TOKENS=100000
# Deprecated: platform trial is now primarily controlled by token / budget, not daily request count
FREE_TRIAL_DAILY_REQUESTS=0
FREE_TRIAL_HOURLY_IP_LIMIT=20
TRIAL_DAILY_BUDGET_CNY=3
TRIAL_MONTHLY_BUDGET_CNY=40
TRIAL_INPUT_COST_PER_MILLION_CNY=1.2
TRIAL_OUTPUT_COST_PER_MILLION_CNY=7.2
TRIAL_LEDGER_PATH=./data/trial-ledger.json

# Optional internal ops dashboard
# Generate the two values below with:
# pnpm ops:hash-password your-admin-password
OPS_DASHBOARD_ENABLED=true
OPS_DASHBOARD_PASSWORD_HASH=
OPS_DASHBOARD_SESSION_SECRET=
OPS_DASHBOARD_TIMEZONE=Asia/Shanghai
